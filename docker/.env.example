# Copy this file to docker/.env for local development. Never commit docker/.env.
# Generate independent secrets, for example: openssl rand -base64 32

DB_NAME=komo
DB_USER=komo
DB_PASSWORD=replace-with-generated-database-password

RABBITMQ_USER=komo
RABBITMQ_PASS=replace-with-generated-rabbitmq-password

ES_USERNAME=elastic
ES_PASSWORD=replace-with-generated-elasticsearch-password

JWT_SECRET=replace-with-at-least-32-random-bytes
DEEPSEEK_API_KEY=replace-with-provider-api-key
